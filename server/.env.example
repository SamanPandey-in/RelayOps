# SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=support.heed@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=support.heed@gmail.com
# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Database - PostgreSQL (update with your actual database URL)
DATABASE_URL=postgresql://username:password@app-id.ap-zone-no.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Direct connection for Prisma CLI
DIRECT_URL=postgresql://username:password@app-id.ap-zone-no.aws.neon.tech/neondb?sslmode=require

# JWT Authentication
JWT_ACCESS_SECRET=random_access_secret_key_64_chars_minimum
JWT_REFRESH_SECRET=random_refresh_secret_key_64_chars_minimum
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cookies
COOKIE_SECRET=dev_cookie_secret_32_chars_minimum

# Email Service (using Nodemailer)
# Example: Gmail - use App Password (not your main password)
# See: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@Heed.com

# For production, use your own email service (SendGrid, AWS SES, etc.)
# Example SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey
# Example AWS SES: SMTP_HOST=email-smtp.region.amazonaws.com, SMTP_PORT=587
