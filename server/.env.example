# Brevo Email Configuration
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=your-verified-sender@example.com
BREVO_SENDER_NAME=Heed
# Server Configuration
PORT=5000
NODE_ENV=development

# Database - PostgreSQL (update with your actual database URL)
DATABASE_URL=postgresql://username:password@app-id.ap-zone-no.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Direct connection for Prisma CLI
DIRECT_URL=postgresql://username:password@app-id.ap-zone-no.aws.neon.tech/neondb?sslmode=require

# JWT Authentication
JWT_ACCESS_SECRET=random_access_secret_key_64_chars_minimum
JWT_REFRESH_SECRET=random_refresh_secret_key_64_chars_minimum
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cookies
COOKIE_SECRET=dev_cookie_secret_32_chars_minimum
